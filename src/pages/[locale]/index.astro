---
// src/pages/[locale]/index.astro
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/hero/Hero.astro";
import Steps from '../../components/features/Steps.astro';
import RelatedProducts from "../../components/related/RelatedProducts.astro";
import FAQ from '../../components/features/FAQ.astro';
import OTPModal from '../../components/auth/OTPModal.astro';


// Generar las rutas
export function getStaticPaths() {
  return [
    { params: { locale: 'es' } },
    { params: { locale: 'en' } },
    { params: { locale: 'de' } },
    { params: { locale: 'it' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'pt' } },
  ];
}

const { locale } = Astro.params;
---

<Layout  lang={locale}>
	
	<Hero lang={locale}/>
	<!-- 
	<HeroNew ></HeroNew>
	<HeroNew2 ></HeroNew2>
	<HeroNew3 ></HeroNew3>
	-->
	<OTPModal></OTPModal>
	<RelatedProducts lang={locale}></RelatedProducts>
	<!-- <Steps />-->
	<!-- <FAQ locale={locale}></FAQ>-->
</Layout>
