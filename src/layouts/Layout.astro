---
import "../styles/global.css";
import Breadcrumb from "../components/navigation/Breadcrumb.astro";
//import PageHeader from "../components/navigation/NavBarOld.astro";
import Header from "../components/navigation/Header.astro";
import StickyForm from "../components/conversion/StickyForm.astro";
import StickyController from "../components/conversion/StickyController.astro";
import Footer from "../components/footer/Footer.astro";
import { useTranslations } from "../utils/i18n";

interface Props {
  title?: string;
  description?: string;
  lang?: string; // El signo ? significa que es opcional
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang as any);

const { title = t("pdf_name"), description = t("pdf_description")} = Astro.props;

// Esto ayuda a que Google sepa exactamente cuál es la URL principal
const canonicalURL = new URL(
  Astro.url.pathname,
  //Astro.site || "http://localhost:4321",
  "https://pdf-landing-gate.vercel.app", // Despliegue en servidor de VERCEL
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} /> <!-- SEO --> 
    <link rel="canonical" href={canonicalURL} />
  </head>

  <body class="bg-slate-50 text-ean-text antialiased">
    <Header lang={lang} />

    <div class="mx-auto max-w-full px-4 lg:max-w-8xl">
      <Breadcrumb lang={lang} />

      <!-- <NavBarOld /> -->

      <main class="grow mt-4">
        <slot />
      </main>

      <Footer lang={lang} />

      
      <StickyForm lang={lang}/>
      <StickyController />
      
    </div>
<script>
      // Importamos el inicializador que creamos en el paso anterior
      import { initPriceObserver } from "../utils/priceFormatter";

      // Lo ejecutamos al cargar la página
      initPriceObserver();

    </script>

  </body>
</html>
