---
// src/components/conversion/StickyForm.astro
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang?: string;
  isSticky?: boolean;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const { isSticky = true } = Astro.props;
---

<div
  id={isSticky ? "sticky-cta" : "footer-cta"}
  class={isSticky
    ? "fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-gray-200 p-4 z-100 translate-y-full transition-transform duration-500 shadow-[0_-10px_25px_-5px_rgba(0,0,0,0.1)]"
    : "relative w-full bg-white/95 backdrop-blur-md border-t border-gray-200 p-4 z-100 translate-y-full transition-transform duration-500 shadow-[0_-10px_25px_-5px_rgba(0,0,0,0.1)]"}
>

  <div class="max-w-7xl mx-auto flex items-center justify-center">
    <!--
<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
       
  <div class="hidden lg:block">
      <p class="text-ean-dark font-bold text-sm uppercase tracking-wider">
        ¿Listo para empezar? <span class="text-ean-blue"
          >Descarga el manual oficial</span
        >
      </p>
    </div>
-->

    <form class="download-form flex flex-1 w-full max-w-2xl gap-2" aria-label={t("search.placeholder")} role="form">
      <input
        type="email"
        name="email"
        placeholder={t("pdf_form_email_placeholder")}
        class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-ean-blue outline-none text-sm"
        aria-label={t("search.placeholder")}
        required
      />
      <button
        type="submit"
        aria-label={t("pdf_form_download")}
        class="bg-ean-blue text-white px-6 py-2.5 rounded-xl font-bold text-xs uppercase transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] cursor-pointer whitespace-nowrap"
      >
        {t("pdf_form_download")}
      </button>
    </form>
  </div>
</div>

<script>
  import { initDownloadEmail } from "../../utils/downloadEmail";

  initDownloadEmail(); // Se ejecuta 1 sola vez al cargar el componente
</script>