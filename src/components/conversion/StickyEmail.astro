---
// src/components/conversion/StickyEmail.astro
---

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-gray-200 p-4 z-100 translate-y-full transition-transform duration-500 shadow-[0_-10px_25px_-5px_rgba(0,0,0,0.1)]"
>
  <div
    class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <div class="hidden lg:block">
      <p class="text-ean-dark font-bold text-sm uppercase tracking-wider">
        ¿Listo para empezar? <span class="text-ean-blue"
          >Descarga el manual oficial</span
        >
      </p>
    </div>

    <form class="flex flex-1 w-full max-w-2xl gap-2">
      <input
        type="email"
        placeholder="Tu email..."
        class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-ean-blue outline-none text-sm"
        required
      />
      <button
        type="submit"
        class="bg-ean-blue text-white px-6 py-2.5 rounded-xl font-bold text-xs uppercase transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] cursor-pointer whitespace-nowrap"
      >
        Enviar PDF
      </button>
    </form>
  </div>
</div>

<script>
  const stickyCta = document.getElementById("sticky-cta");

  window.addEventListener("scroll", () => {
    console.log(window.scrollY);
    const scrollY = window.scrollY; 
    const height = document.documentElement.scrollHeight - window.innerHeight; // Cuánto puedo bajar en total
    const porcentaje = (scrollY / height) * 100;
    // Aparece cuando el usuario baja más de 20%
    if (porcentaje > 20 && porcentaje < 95) {
      stickyCta?.classList.remove("translate-y-full");
      stickyCta?.classList.add("translate-y-0");
    } else {
      stickyCta?.classList.remove("translate-y-0");
      stickyCta?.classList.add("translate-y-full");
    }
  });
</script>
