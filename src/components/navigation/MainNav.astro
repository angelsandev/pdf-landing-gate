---
import { Image } from "astro:assets";
import logoES from "../../assets/logoES.webp";
import logoEN from "../../assets/logoEN.webp";
import logoDE from "../../assets/logoDE.webp";
import logoIT from "../../assets/logoIT.webp";
import logoFR from "../../assets/logoFR.webp";
import logoPT from "../../assets/logoPT.webp"; 

import { useTranslations } from "../../utils/i18n";

interface Props {
  lang?: string;
}
const {lang='es'}= Astro.props;
const t = useTranslations(lang);

const logos = {
  es: logoES,
  en: logoEN,
  de: logoDE,
  it: logoIT,
  fr: logoFR,
  pt: logoPT,
};

const currentLogo = (logos as any)[lang] || logoES;
---

<div class="bg-white">
  <div class="px-5 hidden lg:block">
    <div class="flex justify-between items-center p-2">
      
      <div class="flex items-center">
        <a href={`https://www.electricautomationnetwork.com/${lang}/`} class="cursor-pointer">
          <Image
            src={currentLogo}
            alt="Electric Automation Network"
            loading="eager"
            class="object-contain max-w-87.75 max-h-12.5"
          />
        </a>
      </div>

      <form 
        action={`https://www.electricautomationnetwork.com/${lang}/buscador`} 
        method="post" 
        class="flex w-full max-w-100 xl:max-w-150"
      >
        <input
          type="text"
          name="txtProduct2FindMobile"
          placeholder={t('search.placeholder')}
          class="bg-[#f2f3f5] text-gray-800 text-sm outline-none px-6 py-3 rounded-l-lg w-full border-l border-t border-b border-ean-dark/20 focus:border-ean-dark transition-colors"
          style="border-right: none; border-width: 1px;"
        />
        
        <button 
          type="submit"
          class="bg-ean-dark border-t border-b border-ean-dark text-white py-3 px-5 rounded-r-lg hover:bg-accent cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </form>

      <div class="flex items-center gap-6">
        <a href={`https://www.electricautomationnetwork.com/${lang}/mi-cuenta`} class="text-gray-800 hover:text-ean-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </a>

        <a href={`https://www.electricautomationnetwork.com/${lang}/cart`} class="relative text-gray-800 hover:text-ean-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span class="absolute -top-2 -right-2 bg-ean-blue text-white text-[10px] font-bold w-5 h-5 flex items-center justify-center rounded-full">
            0
          </span>
        </a>
      </div>

    </div>
  </div>
</div>