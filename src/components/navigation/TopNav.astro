---
// src/components/navigation/TopBar.astro
import { LANGUAGES } from "../../utils/languages";
import { CURRENCIES } from "../../utils/currencies";
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang?: string;
}
const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

// Por ahora simulamos que el idioma actual es español
//const currentIso = "es";
const currentCurrencyIso = "EUR";

const currentLanguage = LANGUAGES.find((l) => l.iso === lang) || LANGUAGES[0];
const currentCurrency = CURRENCIES.find((c) => c.iso === currentCurrencyIso) || CURRENCIES[0];
---

<div class="nav-ean text-[11px]">
  <div class="md:px-5 py-0 flex justify-end lg:justify-between items-center h-7">
    <div class="hidden lg:flex items-center text-white text-xs">
      <span class="mr-4">info@electricautomationnetwork.com</span>
      <span class="mr-4">Europe +34 960 640071</span>
      <span class="mr-4">USA +1 305 4472905</span>
    </div>

    <div class="flex items-center text-white h-full ml-auto lg:ml-0">
      <!------------------------SELECT IDIOMA----------------------- -->
      <div class="dropdown-container relative group h-full flex items-center">
        <button
          class="dropdown-btn inline-flex items-center font-medium px-4 text-white text-sm cursor-pointer hover:bg-gray-700 h-full transition-colors"
        >
          <span class="mr-1">{currentLanguage.name}</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg
          >
        </button>

        <div
          class="dropdown-menu absolute right-0 top-full p-2 bg-white rounded-md shadow-xl opacity-0 invisible scale-95
                transition-all duration-200 z-110 min-w-37.5"
        >
          <ul class="py-1">
            {
              LANGUAGES.map((item) => (
                <li>
                  <a
                    href={`/${item.iso}/`}
                    class={`block px-4 py-2 text-sm hover:bg-gray-100 rounded ${item.iso === lang ? "bg-gray-700 text-white" : "text-gray-700"}`}
                  >
                    {item.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <span class="text-white/20 mx-1">|</span>
      <!------------------------SELECT CURRENCY / DIVISA----------------------- -->
      <div class="dropdown-container relative group h-full flex items-center">
        <button
          class="dropdown-btn inline-flex items-center font-medium px-4 text-white text-sm cursor-pointer hover:bg-gray-700 h-full transition-colors"
        >
          <span class="mr-1">{t("nav.currency")} {currentCurrency.name}</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg
          >
        </button>

        <div
          class="dropdown-menu absolute right-0 top-full p-2 bg-white rounded-md shadow-xl opacity-0 invisible scale-95
                transition-all duration-200 z-110 w-max min-w-37.5 max-h-80 overflow-y-auto"
        >
          {
            CURRENCIES.filter((c) => c.active).map((curr) => (
              <a
                href="#"
                class={`block px-4 py-2 text-sm hover:bg-gray-100 rounded ${curr.iso === currentCurrencyIso ? "bg-gray-700 text-white" : "text-gray-700"}`}
              >
                {curr.name} ({curr.iso})
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>

<!----------------SCRIPT PARA MOSTRAR EL DROPDOWN Y ESCONDER EL OTRO---------------- -->
<script>
  const controlDropdowns = () => {
    document.addEventListener("click", (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const currentContainer = target.closest<HTMLElement>(".dropdown-container");
      const allMenus = document.querySelectorAll<HTMLElement>(".dropdown-menu");
      const button = target.closest<HTMLElement>(".dropdown-btn");

      if (!currentContainer) {
        allMenus.forEach((menu) => menu.classList.remove("is-active"));
        return;
      }
      if (button) {
        const currentMenu = currentContainer.querySelector<HTMLElement>(".dropdown-menu");
        allMenus.forEach((menu) => menu.classList.remove("is-active"));
        currentMenu?.classList.toggle("is-active");
      }
    });
  };
  controlDropdowns();
</script>

<style>
  .is-active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }
</style>
