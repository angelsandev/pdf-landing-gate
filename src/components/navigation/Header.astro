---
import TopBar from "./TopBar.astro";
import MainHeader from "./MainHeader.astro";
import Navbar from "./NavBar.astro";

interface Props {
  lang?: string;
}
const { lang = "es" } = Astro.props;
---

<TopBar lang={lang} />

<header class="sticky top-0 z-100 bg-white w-full block shadow-sm">
  <MainHeader lang={lang} />
</header>

<Navbar lang={lang} />
