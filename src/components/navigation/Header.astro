---
import TopNav from "./TopNav.astro";
import MainNav from "./MainNav.astro";
import MenuNav from "./MenuNav.astro";

interface Props {
  lang?: string;
}
const { lang = "es" } = Astro.props;
---

<TopNav lang={lang} />

<header class="sticky top-0 z-50 bg-white w-full block shadow-sm">
  <MainNav lang={lang} />
</header>

<MenuNav lang={lang} />
