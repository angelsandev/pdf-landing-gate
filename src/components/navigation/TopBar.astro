---
// src/components/navigation/TopBar.astro
import { LANGUAGES } from "../../utils/languages";
import { CURRENCIES } from "../../utils/currencies";
// Por ahora simulamos que el idioma actual es español
// En el futuro, esto vendrá de Astro.url o de la configuración
const currentIso = "es";
const currentCurrencyIso = "EUR";

const currentLanguage =
  LANGUAGES.find((l) => l.iso === currentIso) || LANGUAGES[0];
const currentCurrency =
  CURRENCIES.find((c) => c.iso === currentCurrencyIso) || CURRENCIES[0];
---

<div class="nav-ean text-[11px]">
  <div class="container mx-auto px-4 flex justify-between items-center h-7">
    <div class="hidden lg:flex items-center gap-4 text-white/90">
      <span
        class="hover:text-white transition-colors cursor-default select-none"
      >
        info@electricautomationnetwork.com
      </span>
      <div class="flex gap-4">
        <a
          href="tel:+34960640071"
          class="hover:text-ean-blue transition-colors"
        >
          <b>Europe</b> +34 960 640071
        </a>
        <a
          href="tel:+13054472905"
          class="hover:text-ean-blue transition-colors"
        >
          <b>USA</b> +1 305 4472905
        </a>
      </div>
    </div>

    <div class="flex items-center text-white h-full ml-auto lg:ml-0">
      <!------------------------SELECT IDIOMA----------------------- -->
      <div class="relative group h-full flex items-center">
        <button
          class="flex items-center gap-1 px-3 h-full hover:bg-ean-dark transition-colors cursor-pointer"
        >
          <span>{currentLanguage.name}</span>
          <svg
            class="w-3 h-3 opacity-60"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <div
          class="absolute right-0 top-full w-32 bg-white text-ean-text shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 border border-gray-100 py-1"
        >
          {
            LANGUAGES.map((lang) => (
              <a
                href="#"
                class={`block px-4 py-2 hover:bg-ean-dark hover:text-white transition-colors ${lang.iso === currentIso ? "bg-ean-dark text-white font-bold" : ""}`}
              >
                {lang.name}
              </a>
            ))
          }
        </div>
      </div>

      <span class="text-white/20 select-none">|</span>
      <!------------------------SELECT CURRENCY / DIVISA----------------------- -->
      <div class="relative group h-full flex items-center">
        <button
          class="flex items-center gap-1 px-3 h-full hover:bg-ean-dark transition-colors cursor-pointer"
        >
          <span
            >Divisa: <strong class="font-bold text-white ml-1"
              >{currentCurrency.iso}</strong
            ></span
          >
          <svg
            class="w-3 h-3 opacity-60"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          class="absolute right-0 top-full w-38 bg-white text-ean-text shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 border border-gray-100 py-1 normal-case font-normal"
        >
          {
            CURRENCIES.filter((c) => c.active).map((curr) => (
              <a
                href="#"
                class={`flex justify-between px-4 py-2 hover:bg-ean-dark hover:text-white ${curr.iso === currentCurrencyIso ? "bg-ean-dark text-white font-bold" : ""}`}
              >
                <span>
                  {curr.name} ({curr.iso})
                </span>
              </a>
            ))
          }
        </div>
      </div>

      <span class="text-white/20 select-none">|</span>

      <a
        href="#"
        class="px-4 h-full flex items-center hover:bg-ean-dark transition-colors font-bold tracking-tight"
      >
        Iniciar sesión
      </a>
    </div>
  </div>
</div>
