---
// src/components/related/RelatedProducts.astro
import { Image } from "astro:assets";

// 1. Importas las imágenes de tus productos relacionados
// (Asegúrate de que existan en src/assets/productos/)
import producto1 from "../../assets/products/s7-1200-cpu-1214c.jpg";
import producto2 from "../../assets/products/siemens-simatic-hmi-tp400-basic.jpg";
import producto3 from "../../assets/products/siemens-simatic-s7-1200-cpu.jpg";
import producto4 from "../../assets/products/siemens-simatic-hmi-ktp700f-mobile.jpg";

const related = [
    { src: producto1, name: "PLC S7-1200 CPU 1214C" },
    { src: producto2, name: "HMI KTP400 Basic" },
    { src: producto3, name: "PLC S7-1200 CPU 1211C" },
    { src: producto4, name: "HMI KTP700f" },
    // ... más productos
];
---

<section class="mb-16">
    <div class="mb-6 flex items-center justify-between">
        <h2 class="text-2xl font-semibold text-heading">Productos Relacionados</h2>
        
        <div class="flex items-center gap-1 rounded-xl border border-gray-300 bg-white p-1 shadow-sm dark:border-white/10 dark:bg-white/4">
            <span class="px-4 py-1 text-xs font-medium text-muted uppercase tracking-wider">Catálogo 2026</span>
        </div>
    </div>

    <div class="relative overflow-hidden">
        <div class="screenshots-scrollbar overflow-x-auto pb-4 custom-scroll">
            <div class="flex gap-6 w-max">
                {related.map((item) => (
                    <div class="relative shrink-0 overflow-hidden rounded-xl border border-gray-300 dark:border-white/10 shadow-lg group bg-white dark:bg-neutral-900">
                        <Image 
                            src={item.src} 
                            alt={item.name} 
                            width={360}
                            height={270}
                            format="webp"
                            class="rounded-t-xl object-cover aspect-4/3 w-70 md:w-90 group-hover:scale-105 transition-transform duration-500"
                        />
                        <div class="p-4 border-t border-gray-100 dark:border-white/5">
                            <p class="text-sm font-semibold text-heading text-center">{item.name}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    /* Estilizamos el scroll para que sea elegante pero ligero */
    .custom-scroll {
        scrollbar-width: thin;
        scrollbar-color: rgba(0,0,0,0.1) transparent;
    }
    
    .dark .custom-scroll {
        scrollbar-color: rgba(255,255,255,0.1) transparent;
    }
</style>
