---
// src/components/related/RelatedProducts.astro
import { Image } from "astro:assets";
import { dataProduct } from "../../utils/dataProduct";
import { useTranslations } from "../../utils/i18n";

const product = dataProduct.box_bestseller;

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<div class="md:px-5 pb-4 mt-5 md:mt-0">
  <div class="flex flex-row items-center justify-start space-x-4">
    <h2 class="text-lg md:text-2xl text-center font-semibold text-gray-800 pl-2 md:pl-10">
      {t("box_products_best_sellers")}
    </h2>
  </div>

  <!------------------------------BOTONES DEL SLIDER------------------------------ -->
  <div class="relative group border border-gray-300 rounded-lg p-4 bg-white">
    <button
      data-direction="left"
      class="prev-btn
      absolute left-0 top-1/2 -translate-y-1/2 z-10
      w-10 h-10 md:w-12 md:h-12
      bg-white border border-gray-300 rounded-full
      shadow-lg hover:shadow-xl
      flex items-center justify-center
      transition-all duration-200 ease-in-out
      hover:scale-110
      text-gray-700 hover:text-blue-600 hover:border-blue-300 cursor-pointer
      group-hover:visible"
      aria-label={t("box_prev_btn")}
    >
      <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg
      >
    </button>

    <button
      data-direction="right"
      class="next-btn
      absolute right-0 top-1/2 -translate-y-1/2 z-10
      w-10 h-10 md:w-12 md:h-12
      bg-white border border-gray-300 rounded-full
      shadow-lg hover:shadow-xl
      flex items-center justify-center
      transition-all duration-200 ease-in-out
      text-gray-700 hover:text-blue-600 hover:border-blue-300 cursor-pointer
      hover:scale-110
      group-hover:visible"
      aria-label={t("box_next_btn")}
    >
      <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg
      >
    </button>

    <!------------------------------CONTAINER DE PRODUCTOS CON SCROLL------------------------------ -->
    <div
      id="product-scroll"
      class="opacity-0 invisible md:opacity-100 md:visible flex overflow-x-auto space-x-3 md:space-x-2 p-1 scroll-smooth mx-6 md:mx-8 scrollbar-hide -webkit-scrollbar-hide"
      style="content-visibility: hidden; scrollbar-width: none; -ms-overflow-style: none; scroll-snap-type: x mandatory;"
    >
      {
        product.map((item: any) => (
          <div class="shrink-0 scroll-snap-align-start" style="scroll-snap-align: start;">
            <div class="w-30 hover:border-gray-300 hover:scale-105 transition-transform rounded-lg relative">
              <a href={`/${lang}${item.slug}`} class="font-base text-xl mt-2 flex justify-center" aria-label={`Ver detalles de ${item.name}`}>
                <Image
                  src={item.img}
                  alt={item.name}
                  width={70}
                  height={70}
                  format="webp"
                  quality="high"
                  loading="lazy"
                  decoding="async"
                  class="object-contain "
                  style="width: 70px; height: 70px;"
                />
              </a>

              <div class="space-y-1 relative px-1 py-1 ">
                <a href={`/${lang}${item.slug}`} class="font-bold text-xs">
                  <span class="text-center text-blue-600 font-bold">{item.referencia.slice(0, 15)}</span>
                  <p class="product-price-display text-base text-center font-medium text-gray-800" data-base-price={item.price}>{item.price}€</p>
                  <h3 class="font-medium text-center text-gray-800 min-h-15 leading-none">{item.name.slice(0, 41)}</h3>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  const checkScrollability = () => {
    const container = document.getElementById("product-scroll") as HTMLDivElement | null;
    const right = document.querySelector(".next-btn") as HTMLButtonElement | null;
    const left = document.querySelector(".prev-btn") as HTMLButtonElement | null;

    if (!container || !right || !left) {
      return;
    }

    left?.addEventListener("click", () => {
      container.scrollBy({
        left: -300,
        behavior: "smooth",
      });
    });
    right?.addEventListener("click", () => {
      container.scrollBy({
        left: 300,
        behavior: "smooth",
      });
    });

    if (container) {
      // Hacer visible el componente slider
      container.style.contentVisibility = "visible";
      container.classList.remove("opacity-0", "invisible");
    }
  };
  //document.addEventListener("astro:page-load", checkScrollability);
  //checkScrollability();
  // Retardo para hacer visible el componente después de la carga total de la página
  window.addEventListener("load", () => {
    setTimeout(checkScrollability, 1000);
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  #product-scroll {
    min-height: 200px; /* Ajuste según la altura real de las tarjetas */
  }
</style>
