---
// src/components/related/RelatedProducts.astro
import { Image } from "astro:assets";
import producto1 from "../../assets/products/s7-1200-cpu-1214c.jpg";
import producto2 from "../../assets/products/siemens-simatic-hmi-tp400-basic.jpg";
import producto3 from "../../assets/products/siemens-simatic-s7-1200-cpu.jpg";
import producto4 from "../../assets/products/siemens-simatic-hmi-ktp700f-mobile.jpg";

// Simulamos los datos que vendrían del "data" del componente original
const related = [
  { id: 1, src: producto1, name: "PLC S7-1200 CPU 1214C", url: "#", price: 250 },
  { id: 2, src: producto2, name: "HMI KTP400 Basic", url: "#", price: 420 },
  { id: 3, src: producto3, name: "PLC S7-1200 CPU 1211C", url: "#", price: 180 },
  { id: 4, src: producto4, name: "HMI KTP700f Mobile", url: "#", price: 890 },
  { id: 5, src: producto1, name: "Extra PLC Item", url: "#", price: 250 }, // probar el scroll
  { id: 6, src: producto1, name: "Extra PLC Item", url: "#", price: 250 },
  { id: 7, src: producto1, name: "Extra PLC Item", url: "#", price: 250 },
];

interface Props {
  title?: string;
}
const { title = "Productos Relacionados" } = Astro.props;
---

<div class="md:px-5 pb-2 mt-5 md:mt-0">
  <div class="flex flex-row items-center justify-start space-x-4">
    <p class="text-lg md:text-2xl text-center font-semibold text-gray-800 pl-2 md:pl-10">
      {title}
    </p>
  </div>

  <!------------------------------BOTONES DEL SLIDER------------------------------ -->
  <div class="relative group border border-gray-300 rounded-lg p-4 bg-white">
    <button
      data-direction="left"
      class="prev-btn 
      absolute left-0 top-1/2 -translate-y-1/2 z-10 
      w-10 h-10 md:w-12 md:h-12 
      bg-white border border-gray-300 rounded-full 
      shadow-lg hover:shadow-xl
      flex items-center justify-center 
      transition-all duration-200 ease-in-out
      hover:scale-110 
      text-gray-700 hover:text-blue-600 hover:border-blue-300 cursor-pointer 
      disabled:opacity-0 invisible 
      group-hover:visible"
    >
      <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg
      >
    </button>

    <button
      data-direction="right"
      class="next-btn 
      absolute right-0 top-1/2 -translate-y-1/2 z-10 
      w-10 h-10 md:w-12 md:h-12 
      bg-white border border-gray-300 rounded-full 
      shadow-lg hover:shadow-xl
      flex items-center justify-center 
      transition-all duration-200 ease-in-out
      text-gray-700 hover:text-blue-600 hover:border-blue-300 cursor-pointer
      hover:scale-110 
      group-hover:visible"
    >
      <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg
      >
    </button>

    <!------------------------------CONTAINER DE PRODUCTOS CON SCROLL------------------------------ -->
    <div
      id="product-scroll"
      class="flex overflow-x-auto space-x-3 md:space-x-2 p-1 scroll-smooth mx-6 md:mx-8 scrollbar-hide -webkit-scrollbar-hide"
      style="scrollbar-width: none; -ms-overflow-style: none; scroll-snap-type: x mandatory;"
    >
      {
        related.map((item) => (
          <div class="shrink-0 scroll-snap-align-start" style="scroll-snap-align: start;">
            <div class="w-30 hover:border-gray-300 hover:scale-105 transition-transform rounded-lg relative">
            <a href={item.url} class="font-base text-xl mt-2 flex justify-center">
              <Image 
                src={item.src} 
                alt={item.name} 
                width={70} 
                height={70} 
                format="webp"
                quality="high"
                class="object-contain " 
                style="width: 70px; height: 70px;"
                />
            </a>
            
              <div class="space-y-1 relative px-1 py-1 ">
                <a href={item.url} class="font-bold text-xs">
                <h3 class="text-center text-blue-600 font-bold">{item.name}</h3>
                  <p class="text-base text-center font-medium text-gray-800">{item.price}€</p>
                <h3 class="font-medium text-center text-gray-800 min-h-15 leading-none">
                        {item.name}                        
                    </h3>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>


<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
