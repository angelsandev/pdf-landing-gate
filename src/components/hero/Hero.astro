---
import { appData } from "../../data";
import { Image } from "astro:assets";

import logoImage from "../../assets/pdf-download.jpg";
// Extraemos los datos para que el HTML quede limpio
const { featuredManual, name, description, logo, downloadLinks, rating } =
  appData;
---

<div
  class="hero-container mb-16 flex flex-col md:flex-row gap-8 items-start text-center md:text-left"
>
  <div class="shrink-0 self-center md:self-start">
    <div
      class="group/icon rounded-2xl border border-gray-200/50 dark:border-white/10 bg-linear-to-br from-gray-50 to-gray-100 dark:from-white/2 dark:to-white/5 p-7 w-56 h-56 flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300"
    >
      <Image
        src={logoImage}
        alt={`Logo de ${name}`}
        width={192}
        height={192}
        format="webp"
        loading="eager"
        fetchpriority="high"
        class="h-48 w-48 rounded-2xl object-cover group-hover/icon:scale-105 transition-transform duration-300"
      />
    </div>
  </div>

  <div class="flex flex-1 flex-col justify-between">
    <div>
      <h1 class="text-4xl font-bold text-heading mb-2">
        {featuredManual.title}
      </h1>

      <div
        class="flex items-center gap-3 mb-3 justify-center md:justify-start flex-wrap"
      >
        <div class="flex items-center gap-1.5">
          <span class="text-yellow-400">★★★★★</span>
          <span class="text-sm font-medium text-body ml-1">
            · {rating.score} ({rating.count} descargas)
          </span>
        </div>
      </div>

      <div
        class="flex items-center gap-2 mb-4 justify-center md:justify-start flex-wrap text-xs"
      >
        <div class="info-badge">
          <span class="font-semibold text-heading">PDF</span>
          <span class="text-body">{featuredManual.size}</span>
        </div>
        <div class="info-badge">
          <span class="font-semibold text-heading">Actualizado</span>
          <span class="text-body">{featuredManual.releaseDate}</span>
        </div>
      </div>

      <p class="text-lg text-body leading-relaxed max-w-2xl mx-auto md:mx-0">
        {description}
      </p>
    </div>
  </div>

  <!-----------------------FORMULARIO   EMAIL Y BOTÓN DESCARGA ------------------->
  <div
    class="w-full max-w-md mx-auto flex flex-col gap-4 md:mx-0 md:w-64 md:shrink-0"
  >
    <form class="flex flex-col gap-3">
      <div class="flex flex-col gap-1.5">
        <label
          for="email"
          class="text-xs font-semibold text-heading ml-1 uppercase tracking-wider"
        >
          Tu correo electrónico
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="ejemplo@correo.com"
          class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-white/10 bg-white dark:bg-white/5 text-heading focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all placeholder:text-gray-400"
        />
      </div>

      <button
        type="submit"
        class="group button-primary w-full px-5 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
      >
        <span class="flex flex-col items-center">
          <div
            class="text-xs font-medium text-blue-100 group-hover:text-white uppercase"
          >
            Enviar al correo
          </div>
          <div
            class="text-base font-semibold tracking-wide text-white uppercase"
          >
            DESCARGAR PDF
          </div>
        </span>
      </button>
    </form>

    <p class="text-[10px] text-muted text-center leading-tight px-2">
      Al hacer clic, recibirás el manual técnico directamente en tu bandeja de
      entrada.
    </p>
  </div>

  <!-- ----------------------------DOS BOTONES: DESCARGA Y VER ONLINE---------------------------------
  <div
    class="w-full max-w-md mx-auto grid grid-cols-1 xs:grid-cols-2 gap-3 md:flex md:flex-col md:mx-0 md:w-auto md:shrink-0"
  >
    <a
      href={downloadLinks.pdfDownload}
      class="group button-primary px-5 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] md:min-w-50"
    >
      <span class="flex flex-col items-center">
        <div class="text-xs font-medium text-blue-100 group-hover:text-white">
          PDF
        </div>
        <div class="text-base font-semibold tracking-wide text-white">
          DESCARGAR
        </div>
      </span>
    </a>

    
    <a
      href={downloadLinks.pdfView}
      class="group button-primary px-5 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] md:min-w-50"
    >
      <span class="flex flex-col items-center">
        <div class="text-xs font-medium text-blue-100 group-hover:text-white">
          PDF
        </div>
        <div class="text-base font-semibold tracking-wide text-white">
          VER ONLINE
        </div>
      </span>
    </a>
-->
</div>

<style>
  .hero-container {
    animation: fadeInUp 0.5s ease-out forwards;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
