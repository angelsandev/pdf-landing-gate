---
import { appData } from "../../data";
import { Image } from "astro:assets";

import logoImage from "../../assets/pdf-download.jpg";
// Extraemos los datos para que el HTML quede limpio
const { featuredManual, name, description, logo, downloadLinks, rating } = appData;
---

<div class="hero-container mb-16 flex flex-col md:flex-row gap-8 items-start text-center md:text-left">
    
    <div class="shrink-0 self-center md:self-start">
        <div class="group/icon rounded-2xl border border-gray-200/50 dark:border-white/10 bg-linear-to-br from-gray-50 to-gray-100 dark:from-white/2 dark:to-white/5 p-7 w-56 h-56 flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300">
            <Image
                src={logoImage} 
                alt={`Logo de ${name}`}
                width={192} 
                height={192}
                format="webp"
                loading="eager"
                fetchpriority="high"
                class="h-48 w-48 rounded-2xl object-cover group-hover/icon:scale-105 transition-transform duration-300"
            />
        </div>
    </div>

    <div class="flex flex-1 flex-col justify-between">
        <div>
            <h1 class="text-4xl font-bold text-heading mb-2">{featuredManual.title}</h1>

            <div class="flex items-center gap-3 mb-3 justify-center md:justify-start flex-wrap">
                <div class="flex items-center gap-1.5">
                    <span class="text-yellow-400">★★★★★</span>
                    <span class="text-sm font-medium text-body ml-1">
                        · {rating.score} ({rating.count} descargas)
                    </span>
                </div>
                
            </div>

            <div class="flex items-center gap-2 mb-4 justify-center md:justify-start flex-wrap text-xs">
                <div class="info-badge">
                    <span class="font-semibold text-heading">PDF</span>
                    <span class="text-body">{featuredManual.size}</span>
                </div>
                <div class="info-badge">
                    <span class="font-semibold text-heading">Actualizado</span>
                    <span class="text-body">{featuredManual.releaseDate}</span>
                </div>
            </div>

            <p class="text-lg text-body leading-relaxed max-w-2xl mx-auto md:mx-0">
                {description}
            </p>
        </div>
    </div>

    <div class="w-full max-w-md mx-auto grid grid-cols-1 xs:grid-cols-2 gap-3 md:flex md:flex-col md:mx-0 md:w-auto md:shrink-0">
        
        <a href={downloadLinks.pdfDownload} class="group button-base flex items-center justify-start gap-3 px-5 py-4 transition-all duration-200 hover:scale-[1.02] hover:shadow-md active:scale-[0.98] md:min-w-50">
            
            <span class="min-w-0 text-center">
                <div class="text-xs font-medium text-muted group-hover:text-gray-600 dark:group-hover:text-gray-300">Descargar</div>
                <div class="text-base font-semibold tracking-wide text-heading group-hover:text-gray-900 dark:group-hover:text-white">PDF Oficial</div>
            </span>
        </a>

        <a href={downloadLinks.pdfView} class="group button-base flex items-center justify-start gap-3 px-5 py-4 transition-all duration-200 hover:scale-[1.02] hover:shadow-md active:scale-[0.98] md:min-w-50">
            
            <span class="min-w-0 text-left">
                <div class="text-xs font-medium text-muted group-hover:text-gray-600 dark:group-hover:text-gray-300">Ver Online</div>
                <div class="text-base font-semibold tracking-wide text-heading group-hover:text-gray-900 dark:group-hover:text-white">Guía Rápida</div>
            </span>
        </a>

    </div>


<div class="w-full max-w-md mx-auto grid grid-cols-1 xs:grid-cols-2 gap-3 md:flex md:flex-col md:mx-0 md:w-auto md:shrink-0">
    
    <a href={downloadLinks.pdfDownload} class="group button-primary px-5 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] md:min-w-50">
        <span class="flex flex-col items-center">
            <div class="text-xs font-medium text-blue-100 group-hover:text-white">PDF</div>
            <div class="text-base font-semibold tracking-wide text-white">DESCARGAR</div>
        </span>
    </a>

    <a href={downloadLinks.pdfView} class="group button-primary px-5 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] md:min-w-50">
        <span class="flex flex-col items-center">
            <div class="text-xs font-medium text-blue-100 group-hover:text-white">PDF</div>
            <div class="text-base font-semibold tracking-wide text-white">VER ONLINE</div>
        </span>
    </a>

</div>

</div>

<style>
    .hero-container {
        animation: fadeInUp 0.5s ease-out forwards;
    }
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
