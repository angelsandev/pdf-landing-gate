---
// src/components/sections/Hero.astro
import { appData } from "../../data";
import { Image } from "astro:assets";
import logoImage from "../../assets/pdf-download.jpg";
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang?: string;
}
const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const { featuredManual, name, description, logo, downloadLinks, rating } = appData;
---

<div class="hero-container mb-16 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col gap-8">
  <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
    <div class="shrink-0">
      <div
        class="group/icon rounded-2xl border border-gray-200 bg-slate-50 p-4 w-40 h-40 flex items-center justify-center shadow-inner transition-all duration-300"
      >
        <Image
          id="lcp-image"
          src={logoImage}
          alt={`Logo de ${name}`}
          width={120}
          height={120}
          format="webp"
          loading="eager"
          fetchpriority="high"
          class="h-32 w-32 rounded-xl object-contain"
        />
      </div>
    </div>

    <div class="flex-1 text-center md:text-left">
      
      <h1 id="main-h1" style="view-transition-name: main-title; contain: paint;" class="text-2xl font-extrabold text-ean-text mb-3 leading-tight">
        {featuredManual.title}
      </h1>

      <div class="flex items-center gap-3 mb-4 justify-center md:justify-start flex-wrap">
        <div class="flex items-center gap-1.5 bg-yellow-50 px-3 py-1 rounded-full border border-yellow-100">
          <span class="text-yellow-500 text-xl" aria-hidden="true">★★★★★</span>
          <span class="text-xs font-bold text-yellow-700">
            {rating.score}
            <span class="text-yellow-700 font-normal">({rating.count} descargas)</span>
          </span>
        </div>

        <div class="flex gap-2">
          <span class="info-badge text-[10px] uppercase tracking-widest font-bold">PDF {featuredManual.size}</span>
          <span class="info-badge text-[10px] uppercase tracking-widest font-bold">Actualizado: {featuredManual.releaseDate}</span>
        </div>
      </div>

      <p class="text-base md:text-lg text-body leading-relaxed max-w-3xl">
        {description}
      </p>
    </div>
  </div>

  <!-------------------------FORMULARIO EMAIL Y BOTÓN DESCARGAS -------------------------------->
  <div class="w-full bg-slate-50 p-6 md:p-8 rounded-2xl border border-gray-200 shadow-inner">
    <form class="flex flex-col md:flex-row items-end gap-4">
      <div class="flex flex-col gap-2 text-left grow w-full">
        <label for="email" class="text-xs font-bold text-ean-dark ml-1 uppercase tracking-widest">
          {t("pdf_form_email")}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          placeholder={t("pdf_form_email_placeholder")}
          class="w-full h-19 px-6 rounded-xl border border-gray-300 bg-white text-ean-text focus:ring-2 focus:ring-ean-blue focus:border-transparent outline-none transition-all shadow-sm text-lg"
        />
      </div>

      <button
        type="submit"
        aria-label={t("pdf_form_download")}
        class="group w-full md:w-auto md:px-16 h-19 cursor-pointer transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] bg-ean-blue rounded-xl shadow-lg shadow-blue-200 whitespace-nowrap"
      >
        <div class="flex flex-col items-center">
          <span class="text-xl font-black tracking-wide text-white uppercase">{t("pdf_form_download")}</span>
        </div>
      </button>
    </form>

    <p class="text-xs text-gray-600 mt-4 italic">
      {t("pdf_form_privacy")}
    </p>
  </div>
</div>
